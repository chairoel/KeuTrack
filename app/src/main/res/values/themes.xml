<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SplashTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/animated_splash</item>
        <item name="windowSplashScreenBackground">@color/splash_screen_background</item>
        <item name="postSplashScreenTheme">@style/Theme.KeuTrack</item>
    </style>

    <!-- Financial light — aligned with KeuTrackTheme lightColorScheme -->
    <style name="Theme.KeuTrack" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/financial_primary</item>
        <item name="android:colorPrimaryDark">@color/financial_primary</item>
        <item name="android:colorAccent">@color/financial_secondary</item>
        <item name="android:windowBackground">@color/financial_background</item>
        <item name="android:textColorPrimary">@color/financial_on_surface</item>
        <item name="android:statusBarColor">@color/financial_primary</item>
        <item name="android:navigationBarColor">@color/financial_surface_lowest</item>
    </style>
</resources>
